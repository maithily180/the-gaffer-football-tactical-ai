# Ollama settings
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

# Model paths (relative to project root)
DETECTION_MODEL_PATH=weights/yolov11_football.pt
DETECTION_MODEL_OPENVINO_PATH=weights/yolov11_football_openvino

# Processing defaults
DEFAULT_COMMENTARY_MODE=tactical
DEFAULT_FPS=25
DETECT_EVERY_N_FRAMES=3
DETECTION_IMG_SIZE=640
DETECTION_CONF=0.35

# Output
OUTPUT_DIR=outputs/
LOG_LEVEL=INFO

# Development / dataset download
ROBOFLOW_API_KEY=your_key_here
